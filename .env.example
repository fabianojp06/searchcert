GOOGLE_DRIVE_ROOT_FOLDER_ID=YOUR_ROOT_FOLDER_ID
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/google-service-account.json
GOOGLE_DRIVE_INCLUDE_SHARED_DRIVES=true

# Supabase (para persistência do US003)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
US003_PUSH_SUPABASE=false

# API (US004)
API_PORT=8001

# Poller (US002+US003+Supabase)
POLL_INTERVAL_SECONDS=300
POLL_MAX_PAGES=3
POLL_DEBUG_DIR=
POLL_CHECKPOINT_FILE=output/poller_checkpoint.json

